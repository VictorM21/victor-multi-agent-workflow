# =============================================================
# victor-multi-agent-workflow - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ------------------------------------------------------------------
# Anthropic (REQUIRED)
# ------------------------------------------------------------------
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------------------------------------------------------------------
# Agent Model Configuration
# ------------------------------------------------------------------
# Supervisor agent (orchestration, planning, synthesis)
SUPERVISOR_MODEL=claude-3-5-sonnet-20241022

# Worker agents (faster/cheaper for individual sub-tasks)
WORKER_MODEL=claude-3-haiku-20240307

# Maximum concurrent worker agents
MAX_WORKERS=3

# ------------------------------------------------------------------
# Human-in-the-Loop Configuration
# ------------------------------------------------------------------
# Seconds to wait for human approval before timeout
CHECKPOINT_TIMEOUT=300

# Whether to require approval at every worker step (true/false)
REQUIRE_APPROVAL=false

# ------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------
# Redis for task state (install Redis or use Docker)
REDIS_URL=redis://localhost:6379

# SQLite database for audit log
DATABASE_URL=sqlite:///./data/audit.db

# ------------------------------------------------------------------
# API Server
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# ------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
